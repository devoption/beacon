{{- if and .Values.secret.create (not .Values.secret.existingSecretName) .Values.secret.env }}
apiVersion: v1
kind: Secret
metadata:
  name: {{ include "{{chart_name}}.secretName" . }}
  labels:
    {{- include "{{chart_name}}.labels" . | nindent 4 }}
type: Opaque
stringData:
  {{- range $name, $value := .Values.secret.env }}
  {{ $name }}: {{ $value | quote }}
  {{- end }}
{{- end }}
